# ============================================================
#  AI Solopreneur OS — environment template
#  Copy this file to ".env" and fill in only what you use.
#  NEVER commit your real .env (it is gitignored).
# ============================================================

# --- Claude Code ---
# The OS runs on your existing Claude Code login (Claude Pro minimum).
# You do NOT need an Anthropic API key for normal skill use.
# Only set this if you wire the optional W_Counsel voice/3D app to the API directly.
ANTHROPIC_API_KEY=

# --- Google Workspace connector (gws CLI) ---
# Optional. Lets the OS read/write your own Gmail, Drive, Calendar, Sheets, Docs.
# See connectors/README.md for how to obtain these via Google Cloud OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Image generation (optional, paid) ---
# Only needed if you render images from skills like /carousel. Paid per image.
# Leave blank to run those skills in brief-only mode (no render, no spend).
KIE_API_KEY=

# --- W_Counsel mascot app (optional) ---
# The optional voice/3D shell is a SEPARATE app with its own settings — nothing to set here.
# To point it at this OS folder, see w-counsel/README.md.
